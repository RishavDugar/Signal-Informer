# Environment & secrets
.env

# Python
__pycache__/
*.pyc
*.pyo

# Logs
logs/
*.log

# Database files (large binaries, regenerated locally)
db/*.db
db/backups/

# Generated intraday backtest results (large, regenerated locally)
db/hft_results.json

# Intraday parquet data store (large, copied locally)
data/hft/

# Python virtual environment
.venv/

# WhatsApp bridge: superseded by the shared whatsapp_bridge package
# (github.com/RishavDugar/WhatsApp-Bridge). A few Chrome session-cache files
# under .wwebjs_auth can't be deleted (Chrome sandbox ACL denies even the
# owner) until reboot — ignore the leftover directory entirely.
notifications/whatsapp_bridge/

# Generated cache files
PyWhatKit_DB.txt

# Claude Code local settings (machine-specific)
.claude/settings.local.json
.claude/scheduled_tasks.lock
